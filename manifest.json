{
    "manifest_version": 3,
    "name": "Leetcode Revision Extension",
    "version": "0.1.0",
    "description": "Monitors solving patterns on LeetCode, calculates struggle score, and generates a personalized revision queue.",

    "permissions": [
        "storage",
        "alarms",
        "cookies"
    ],

    "host_permissions": [
        "https://leetcode.com/*"    
    ],

    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },

    "content_scripts": [
        {
            "matches": ["https://leetcode.com/*"],
            "js": ["content/content-script.js"],
            "run_at": "document_idle"
        }
    ],

    "action": {
        "default_popup": "popup/popup.html"
    },

    "web_accessible_resources": [
    {
      "resources": [
        "content/injected.js",
        "engine/bootstrap.js",
        "engine/score.js",
        "engine/storage.js"
      ],
      "matches": [
        "https://leetcode.com/*"
      ]
    }
  ]
}